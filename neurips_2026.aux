\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Overview of \textbf  {Step-dLLM}. Anchor steps compute full attention and extract a block-sparse mask via a fused kernel. Non-anchor steps reuse the cached mask with fresh $\mathbf  {Q}, \mathbf  {K}, \mathbf  {V}$, reducing per-step cost from $\mathcal  {O}(L^2)$ to $\mathcal  {O}(L \cdot k \cdot b)$. The mask is periodically refreshed every $\Delta $ steps.}}{6}{figure.caption.8}\protected@file@percent }
\newlabel{fig:step_dllm_overview}{{4}{6}{Overview of \textbf {Step-dLLM}. Anchor steps compute full attention and extract a block-sparse mask via a fused kernel. Non-anchor steps reuse the cached mask with fresh $\mathbf {Q}, \mathbf {K}, \mathbf {V}$, reducing per-step cost from $\mathcal {O}(L^2)$ to $\mathcal {O}(L \cdot k \cdot b)$. The mask is periodically refreshed every $\Delta $ steps}{figure.caption.8}{}}
\newlabel{fig:step_dllm_overview@cref}{{[figure][4][]4}{[1][5][]6}{}{}{}}
